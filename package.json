{
  "name": "terminal-guardian-mcp",
  "version": "1.0.2",
  "description": "Secure Model Context Protocol server for safe, sandboxed terminal access for AI assistants",
  "main": "dist/index.js",
  "bin": {
    "terminal-guardian-mcp": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "terminal",
    "ai",
    "claude",
    "anthropic",
    "security",
    "sandbox",
    "docker",
    "git"
  ],
  "author": "Terminal Guardian Contributors",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dockerode": "^4.0.2",
    "glob": "^11.0.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "terminal-guardian-mcp": "^1.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.31",
    "@types/node": "^22.7.4",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitest/coverage-v8": "^2.1.1",
    "eslint": "^9.11.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/7Majesty-M/terminal-guardian-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/7Majesty-M/terminal-guardian-mcp/issues"
  },
  "homepage": "https://github.com/7Majesty-M/terminal-guardian-mcp#readme"
}
